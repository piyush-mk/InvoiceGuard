# ── InvoiceGuard Environment Variables ──────────────────────────
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# These are read by inference.py via python-dotenv.
# Never commit .env to git (it's already in .gitignore).
# ────────────────────────────────────────────────────────────────

# 1. API_BASE_URL — The LLM API endpoint.
#    OpenAI:         https://api.openai.com/v1
#    HF Inference:   https://api-inference.huggingface.co/v1
#    Local/custom:   http://localhost:8080/v1
API_BASE_URL=https://api.openai.com/v1

# 2. MODEL_NAME — The model identifier for inference.
#    ┌─────────────────────┬──────────────────┬─────────────┐
#    │ Model               │ Input $/MTok     │ Best for    │
#    ├─────────────────────┼──────────────────┼─────────────┤
#    │ gpt-5.4-nano        │ $0.20            │ Cheapest    │
#    │ gpt-5.4-mini        │ $0.75            │ Best value  │
#    │ gpt-5.4             │ $2.50            │ Strongest   │
#    │ gpt-4o-mini         │ legacy           │ Fallback    │
#    └─────────────────────┴──────────────────┴─────────────┘
#    HF models: meta-llama/Llama-3.1-8B-Instruct, etc.
MODEL_NAME=gpt-4o-mini

# 3. OPENAI_API_KEY — Your API key for the LLM provider.
#    OpenAI: starts with sk-...
#    HF: use your HF token (hf_...)
OPENAI_API_KEY=sk-your-openai-key-here

# 4. HF_TOKEN — Your Hugging Face token.
#    Get one at: https://huggingface.co/settings/tokens
#    Used for deployment (openenv push) and optionally as API key.
HF_TOKEN=hf_your-token-here
